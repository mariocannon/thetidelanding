---
// The Tide — newsletter signup landing page.
// Self-contained on purpose: no web fonts, no external CSS/JS, no images,
// so the page ships as a single small HTML document.
const title = 'The Tide — a newsletter worth waiting for';
const description =
  'The Tide is a short, sharp email newsletter. One idea per issue, straight to your inbox. Sign up with just your email.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#04121f" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8C%8A%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <main>
      <p class="eyebrow">A newsletter, once a week</p>
      <h1>The Tide</h1>
      <p class="tagline">
        One clear idea per issue. No noise, no spam, nothing to scroll past.
        It arrives, you read it in three minutes, you're glad it came.
      </p>

      <form id="signup" method="post" action="#" novalidate>
        <label class="visually-hidden" for="email">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          inputmode="email"
          autocomplete="email"
          spellcheck="false"
          placeholder="you@example.com"
          required
        />
        <button type="submit">Sign up</button>
      </form>
      <p class="note" id="form-note" role="status" aria-live="polite">
        Free forever. Unsubscribe any time.
      </p>
    </main>

    <svg class="waves" viewBox="0 0 1440 220" preserveAspectRatio="none" aria-hidden="true">
      <path
        fill="#0b2c44"
        d="M0,96 C240,160 480,32 720,64 C960,96 1200,192 1440,128 L1440,220 L0,220 Z"
      ></path>
      <path
        fill="#0e3a58"
        opacity="0.8"
        d="M0,160 C280,96 520,208 760,176 C1000,144 1240,96 1440,176 L1440,220 L0,220 Z"
      ></path>
    </svg>

    <script is:inline>
      const form = document.getElementById('signup');
      const email = document.getElementById('email');
      const note = document.getElementById('form-note');

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!email.checkValidity()) {
          note.textContent = 'Please enter a valid email address.';
          note.className = 'note error';
          email.focus();
          return;
        }
        // Wire this up to your email provider (Buttondown, ConvertKit,
        // Supabase, …) — for now the form confirms locally.
        form.hidden = true;
        note.textContent = "You're in. Watch your inbox for the next issue of The Tide.";
        note.className = 'note success';
      });

      email.addEventListener('input', () => {
        if (note.classList.contains('error')) {
          note.textContent = 'Free forever. Unsubscribe any time.';
          note.className = 'note';
        }
      });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
    margin: 0;
  }

  html,
  body {
    height: 100%;
  }

  body {
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 90% at 50% 0%, #0a2b45 0%, #04121f 60%);
    color: #e8f1f8;
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      Roboto,
      sans-serif;
    -webkit-font-smoothing: antialiased;
    text-align: center;
    overflow-x: hidden;
  }

  main {
    width: min(40rem, 100% - 3rem);
    padding-block: 4rem 8rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6fc3e8;
  }

  h1 {
    margin-top: 0.75rem;
    font-size: clamp(3rem, 3.5vw + 2.2rem, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    background: linear-gradient(100deg, #eaf6ff 30%, #7fd0f5 70%, #3ea8dd);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .tagline {
    margin: 1.25rem auto 0;
    max-width: 34rem;
    font-size: clamp(1.05rem, 0.5vw + 0.95rem, 1.25rem);
    line-height: 1.6;
    color: #a9c2d4;
    text-wrap: balance;
  }

  form[hidden] {
    display: none;
  }

  form {
    display: flex;
    gap: 0.6rem;
    margin: 2.5rem auto 0;
    max-width: 28rem;
  }

  input {
    flex: 1;
    min-width: 0;
    padding: 0.9rem 1.1rem;
    font: inherit;
    color: inherit;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.65rem;
    transition: border-color 0.15s;
  }

  input::placeholder {
    color: #7d95a7;
  }

  input:focus-visible {
    outline: none;
    border-color: #6fc3e8;
    box-shadow: 0 0 0 3px rgba(111, 195, 232, 0.25);
  }

  button {
    padding: 0.9rem 1.6rem;
    font: inherit;
    font-weight: 700;
    color: #04121f;
    background: linear-gradient(120deg, #8fd8f8, #4db2e4);
    border: 0;
    border-radius: 0.65rem;
    cursor: pointer;
    transition: transform 0.12s, box-shadow 0.12s;
  }

  button:hover,
  button:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(77, 178, 228, 0.35);
  }

  button:active {
    transform: translateY(0);
  }

  .note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: #7d95a7;
  }

  .note.error {
    color: #ffb3ad;
  }

  .note.success {
    font-size: 1.05rem;
    color: #9fe6c3;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .waves {
    position: fixed;
    inset: auto 0 0;
    width: 100%;
    height: clamp(90px, 18vh, 220px);
    pointer-events: none;
  }

  @media (max-width: 30rem) {
    form {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    button {
      transition: none;
    }
  }
</style>
